{
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": [
      "svelte",
      "vitest/globals",
      "dom-navigation",
      "wicg-file-system-access",
      "sharedworker"
    ]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "playground", "tests"]
}
