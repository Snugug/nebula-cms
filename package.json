{
  "name": "nebula-cms",
  "version": "0.1.7",
  "description": "A native CMS for Astro",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Snugug/nebula-cms"
  },
  "exports": {
    ".": {
      "types": "./dist/astro/index.d.ts",
      "default": "./dist/astro/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "svelte": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts"
    }
  },
  "scripts": {
    "prebuild": "node scripts/subset-icons.mjs",
    "build": "svelte-package --input src --output dist",
    "lint": "prettier -c .",
    "check": "svelte-check",
    "fix": "prettier --write .",
    "test": "vitest run",
    "test:continuous": "vitest"
  },
  "keywords": [
    "cms",
    "astro",
    "astro-integration"
  ],
  "dependencies": {
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/language-data": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/highlight": "^1.0.0",
    "js-yaml": "^4.1.0",
    "smol-toml": "^1.6.1"
  },
  "peerDependencies": {
    "@astrojs/svelte": "^8.0.0",
    "astro": "^6.1.0",
    "svelte": "^5.0.0"
  },
  "author": "Sam Richard<sam@snug.ug>",
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.26.0",
  "devDependencies": {
    "@astrojs/svelte": "^8.0.3",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.3.1",
    "@types/dom-navigation": "^1.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/sharedworker": "^0.0.223",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "astro": "^6.0.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
